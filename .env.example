# Discord 봇 토큰 — router가 Discord Gateway에 연결하기 위한 단일 토큰.
# OpenClaw 측 discord 채널은 비활성화되어 있어야 하며, 이 토큰은 router 단독 소유여야 한다.
DISCORD_BOT_TOKEN=

# Discord 봇이 응답할 길드 ID (선택). 비워두면 모든 길드 + DM 처리.
# 운영 환경 격리용.
DISCORD_GUILD_ID=

# 사용자별 데이터 저장 루트 (mju-cli `--app-dir` 기준 경로).
# mjuclaw-setup의 named volume과 동일한 마운트 포인트를 가리켜야 한다.
USER_DATA_ROOT=/data/users

# OpenClaw Gateway WebSocket URL. 같은 docker-compose network에서는 컨테이너 이름으로.
OPENCLAW_GATEWAY_URL=ws://mjuclaw-agent:18789

# OpenClaw Gateway 인증 토큰 (필요 시).
OPENCLAW_GATEWAY_TOKEN=

# `openclaw` 바이너리 경로 (router 컨테이너 안). 비워두면 PATH에서 탐색.
OPENCLAW_BIN=openclaw

# `mju` 바이너리 경로 (router 컨테이너 안). 비워두면 PATH에서 탐색.
MJU_BIN=mju

# 로깅 레벨: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# 노드 실행 환경: development|production
NODE_ENV=production

# ── HTTP 서버 (cron alert 우회용 inbound) ───────────────────────
# `mjuclaw-setup`의 `bin/mju-news-alert` `bin/mju-attendance-alert`가
# OpenClaw discord channel 비활성화 이후 router로 메시지를 위임하기 위해 사용한다.
# 같은 docker-compose 네트워크 안에서만 접근하도록 하고 host port mapping은 하지 말 것.
HTTP_PORT=3100
HTTP_BIND_HOST=0.0.0.0
# 16자 이상. `openssl rand -hex 32` 권장. router/agent 양쪽 env에 동일 값으로 둔다.
HTTP_AUTH_TOKEN=replace-me-with-openssl-rand-hex-32

# ── Intent classifier (MVP-2) ──────────────────────────────────
# mjuclaw-intent-serving HTTP 호출 — abuse 차단 + (향후) service 라우팅 분기.
# false면 모든 onboarded 메시지를 그대로 openclaw로 forward (MVP-1 동작).
CLASSIFIER_ENABLED=false
CLASSIFIER_URL=http://mjuclaw-classifier:3200
CLASSIFIER_AUTH_TOKEN=
# 분류 호출 timeout (ms). 초과 시 fail-open으로 forward 진행.
CLASSIFIER_TIMEOUT_MS=2500
